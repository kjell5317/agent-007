# Points actions.
#
# The Points page shows your current total, then three sections — Sport,
# Nutrition, Other — each listing the actions below. Submitting an action
# adds `factor * quantity` points:
#   * with a `unit`  -> the page shows a number input; quantity = what you type
#   * without a unit -> the page shows just a button; quantity = 1
#
# Each action needs a `name` and a `factor`; `unit` is optional. Add as many
# as you like under each section.
#
# `task_done_factor` is points-per-estimated-minute awarded automatically when
# a task is completed (e.g. 0.1 -> a 30-minute task earns 3 points). Set to 0
# to disable task-completion points.

task_done_factor: 0.2

sport:
  - name: Run
    factor: 3
    unit: km
  - name: Walk (30min)
    factor: 5
  - name: Workout
    factor: 10
