# --- App ---
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8001
LOG_LEVEL=INFO

# --- Database ---
# Postgres with pgvector extension
DATABASE_URL=postgresql+psycopg://taskagent:taskagent@localhost:5432/taskagent

# --- Location / commute ---
# HOME_ADDRESS is the origin/destination for commute planning + weather. Use a
# full street address Google Maps can geocode. Commute features are disabled
# while it's empty.
USER_TIMEZONE=Europe/Berlin
HOME_ADDRESS=
# Minimum lead before "now" a freshly planned slot may start at.
SLOT_MIN_LEAD_MINUTES=15

# --- Secrets ---
# TODO: generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# --- LLM (Haystack-backed; Anthropic is the initial supported provider) ---
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-7
ANTHROPIC_API_KEY=
# Deprecated compatibility alias; prefer LLM_MODEL.
# CLAUDE_MODEL=claude-opus-4-7

# --- Embeddings (Gemini; used for hybrid candidate retrieval + input dedup) ---
# gemini-embedding-001 supports outputDimensionality of 768 / 1536 / 3072.
# 1536 matches tasks.embedding and raw_inputs.embedding column dims.
GEMINI_API_KEY=
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=1536

# Cosine similarity at/above which a new raw input copies the decision of a
# past one without an LLM call. Range [0,1]; tune up if false auto-decisions
# happen, down if obvious duplicates leak through. Compared against the
# recency-DECAYED similarity (see INPUT_SIMILARITY_HALF_LIFE_DAYS).
INPUT_DEDUP_THRESHOLD=0.88

# Recency decay (e-folding, days) applied to similarity scores before ranking
# and before the auto-decide threshold above — old precedents stop
# auto-deciding and fall through to the agent instead.
INPUT_SIMILARITY_HALF_LIFE_DAYS=100
NOTES_SIMILARITY_HALF_LIFE_DAYS=100

# --- OAuth: Google (Gmail + Calendar + health/sleep + SSO login) ---
# One Google OAuth client serves both:
#   - Gmail data access       (scope: gmail.readonly)
#   - Calendar event access   (scope: calendar.events)
#   - Google Fit sleep access (scope: fitness.sleep.read)
#   - Login SSO               (scopes: openid email)
# Add BOTH redirect URIs below to the client's allowed redirect URIs in
# Google Cloud Console. Enable the Gmail, Calendar, and Fitness APIs on the
# same project as needed. Existing users must re-consent after scope changes.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8001/oauth/google/callback
GOOGLE_OAUTH_LOGIN_REDIRECT_URI=http://localhost:8001/auth/callback

# --- Auth (Google SSO + email allowlist) ---
# Comma-separated emails allowed to log in. Leave empty to disable auth
# (any visitor can hit the app — fine for local dev only).
AUTH_ALLOWED_EMAILS=
# Required when AUTH_ALLOWED_EMAILS is non-empty. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# --- Home Assistant (push notifications) ---
# Create a Long-Lived Access Token in HA (profile → bottom). The notify
# service slug is whatever follows `notify.` in your HA automations.
# Leave URL or TOKEN empty to disable notifications.
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=
HOME_ASSISTANT_NOTIFY_SERVICE=notify
# input_datetime entity kept in sync with the next relevant calendar event.
HOME_ASSISTANT_NEXT_EVENT_ENTITY_ID=input_datetime.007
# Shared secret HA must send (X-Notify-Secret header or ?secret=) on the
# notification-action and points-adjust webhooks. Empty disables the check.
HOME_ASSISTANT_ACTION_SECRET=

# --- Points ---
# Points awarded per estimated minute when a non-kotx task is completed (0 disables).
# Kotx-linked task completions always award 0.1 points per estimated minute.
POINTS_TASK_DONE_FACTOR=0.2

# --- OAuth: Slack ---
# Slack apps are workspace-scoped. Create one app per workspace, add the
# redirect URI below to each, and request these USER scopes on each:
#   channels:read, channels:history,
#   groups:read,   groups:history,
#   im:read,       im:history,
#   mpim:read,     mpim:history,
#   users:read
# Note: `*:read` scopes list conversations; `*:history` read messages from them.
#
# Provide all apps as a single JSON object keyed by a short app name (your
# choice — used as the `?app=` query param on /oauth/slack/authorize):
SLACK_APPS={"primary":{"client_id":"","client_secret":""},"work":{"client_id":"","client_secret":""}}
SLACK_OAUTH_REDIRECT_URI=http://localhost:8001/oauth/slack/callback
SLACK_BOOTSTRAP_DAYS=1

# --- kotx (external coding-agent API) ---
# The frontend's "Runs" tab proxies through the backend under /kotx so the
# bearer token never reaches the browser. Point this at the kotx app and paste
# its API token. Leave either blank to disable the tab (the proxy answers 503).
KOTX_BASE_URL=https://code.kjellhanken.de
KOTX_API_TOKEN=
# Shared secret for the incoming kotx state webhook (POST /webhooks/kotx,
# X-Kotx-Signature: sha256=<hmac>). Must match the kotx deployment. Empty
# disables the endpoint; the reconciliation poll still works without it.
KOTX_WEBHOOK_SECRET=

# --- OAuth providers (template for future sources) ---
# OAUTH_<PROVIDER>_CLIENT_ID=
# OAUTH_<PROVIDER>_CLIENT_SECRET=
# OAUTH_<PROVIDER>_REDIRECT_URI=http://localhost:8001/oauth/<provider>/callback

# --- MCP servers (optional) ---
# TODO: configure MCP endpoints when adding GitHub / Notion
# MCP_GITHUB_URL=
# MCP_NOTION_URL=
