# --- App ---
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8001
LOG_LEVEL=INFO

# --- Database ---
# Postgres with pgvector extension
DATABASE_URL=postgresql+psycopg://taskagent:taskagent@localhost:5432/taskagent

# --- Secrets ---
# TODO: generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=
# TODO: pin a specific model version when ready
CLAUDE_MODEL=claude-opus-4-7

# --- Embeddings (Gemini; used for hybrid candidate retrieval + input dedup) ---
# gemini-embedding-001 supports outputDimensionality of 768 / 1536 / 3072.
# 1536 matches tasks.embedding and raw_inputs.embedding column dims.
GEMINI_API_KEY=
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=1536

# Cosine similarity at/above which a new raw input copies the decision of a
# past one without an LLM call. Range [0,1]; tune up if false auto-decisions
# happen, down if obvious duplicates leak through.
INPUT_DEDUP_THRESHOLD=0.88

# --- OAuth: Google (Gmail + SSO login) ---
# One Google OAuth client serves both:
#   - Gmail data access (scopes: openid email gmail.readonly)
#   - Login SSO       (scopes: openid email profile)
# Add BOTH redirect URIs below to the client's allowed redirect URIs in
# Google Cloud Console. Enable the Gmail API on the same project.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8001/oauth/google/callback
GOOGLE_OAUTH_LOGIN_REDIRECT_URI=http://localhost:8001/auth/callback

# --- Auth (Google SSO + email allowlist) ---
# Comma-separated emails allowed to log in. Leave empty to disable auth
# (any visitor can hit the app — fine for local dev only).
AUTH_ALLOWED_EMAILS=
# Required when AUTH_ALLOWED_EMAILS is non-empty. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# --- Home Assistant (push notifications) ---
# Create a Long-Lived Access Token in HA (profile → bottom). The notify
# service slug is whatever follows `notify.` in your HA automations.
# Leave URL or TOKEN empty to disable notifications.
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=
HOME_ASSISTANT_NOTIFY_SERVICE=notify

# --- OAuth: Slack ---
# Slack apps are workspace-scoped. Create one app per workspace, add the
# redirect URI below to each, and request these USER scopes on each:
#   channels:read, channels:history,
#   groups:read,   groups:history,
#   im:read,       im:history,
#   mpim:read,     mpim:history,
#   users:read
# Note: `*:read` scopes list conversations; `*:history` read messages from them.
#
# Provide all apps as a single JSON object keyed by a short app name (your
# choice — used as the `?app=` query param on /oauth/slack/authorize):
SLACK_APPS={"primary":{"client_id":"","client_secret":""},"work":{"client_id":"","client_secret":""}}
SLACK_OAUTH_REDIRECT_URI=http://localhost:8001/oauth/slack/callback
SLACK_BOOTSTRAP_DAYS=1

# --- WhatsApp Business (Meta Cloud API) ---
# Webhook-driven, no OAuth. Inbound messages POST to /webhooks/whatsapp.
# Setup (developers.facebook.com → your app → WhatsApp):
#   1. APP_SECRET: App Settings → Basic → App Secret. Meta signs every POST
#      with it (X-Hub-Signature-256); we verify before parsing.
#   2. VERIFY_TOKEN: any string you choose. Enter the same value in the
#      webhook config "Verify token" field; Meta echoes it on the GET
#      handshake so we can confirm the subscription.
#   3. Point the webhook Callback URL at https://<your-domain>/webhooks/whatsapp
#      and subscribe to the "messages" field. (Local dev: tunnel via ngrok.)
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# --- OAuth providers (template for future sources) ---
# OAUTH_<PROVIDER>_CLIENT_ID=
# OAUTH_<PROVIDER>_CLIENT_SECRET=
# OAUTH_<PROVIDER>_REDIRECT_URI=http://localhost:8001/oauth/<provider>/callback

# --- MCP servers (optional) ---
# TODO: configure MCP endpoints when adding GitHub / Notion
# MCP_GITHUB_URL=
# MCP_NOTION_URL=
