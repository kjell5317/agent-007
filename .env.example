# --- App ---
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

# --- Database ---
# Postgres with pgvector extension
DATABASE_URL=postgresql+psycopg://taskagent:taskagent@localhost:5432/taskagent

# --- Redis (for background queue) ---
REDIS_URL=redis://localhost:6379/0

# --- Secrets ---
# TODO: generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=
# TODO: pin a specific model version when ready
CLAUDE_MODEL=claude-opus-4-7

# --- OAuth providers (placeholders — fill per source when implementing) ---
# Example shape, repeat per provider:
# OAUTH_<PROVIDER>_CLIENT_ID=
# OAUTH_<PROVIDER>_CLIENT_SECRET=
# OAUTH_<PROVIDER>_REDIRECT_URI=http://localhost:8000/oauth/<provider>/callback

